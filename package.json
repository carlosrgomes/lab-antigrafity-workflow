    "eslint-plugin-jsdoc": "^48.2.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "prisma": "^7.8.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
