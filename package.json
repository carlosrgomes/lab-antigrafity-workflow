{
  "name": "retrovault",
  "version": "1.0.0",
  "description": "RetroVault - Retro Game E-commerce",
  "main": "dist/backend/server.js",
  "scripts": {
    "dev:backend": "tsx watch src/backend/server.ts",
    "dev:frontend": "vite",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "express": "^4.18.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-jsdoc": "^48.2.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "prisma": "^5.10.2",
    "ts-jest": "^29.1.2",
    "tsx": "^4.23.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
